# Credentials and sensitive variable values
terraform.tfvars
*.tfvars

# Terraform state (may contain sensitive data)
terraform.tfstate
terraform.tfstate.backup

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Downloaded and customized cloud images (large binaries)
scripts/.image-cache/

# Kubeconfig written by Terraform after k3s bootstraps (contains cluster credentials)
k3s.kubeconfig
